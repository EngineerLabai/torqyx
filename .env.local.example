# Public site configuration
# Keep INDEX_SITE=false until the final domain is connected and ready for launch.
NEXT_PUBLIC_SITE_URL="https://torqyx.com"
SITE_URL="https://torqyx.com"
INDEX_SITE="false"

# Database connection
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aiengineerslab"

# OpenAI API configuration
OPENAI_API_KEY="REPLACE_WITH_OPENAI_API_KEY"

# AI summary provider configuration
AI_PROVIDER="gemini"
GEMINI_API_KEY="REPLACE_WITH_GEMINI_API_KEY"
GROQ_API_KEY="REPLACE_WITH_GROQ_API_KEY"

# Auth configuration
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_SECRET"
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Firebase client configuration
NEXT_PUBLIC_FIREBASE_API_KEY="REPLACE_WITH_FIREBASE_API_KEY"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="REPLACE_WITH_FIREBASE_AUTH_DOMAIN"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="REPLACE_WITH_FIREBASE_PROJECT_ID"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="REPLACE_WITH_FIREBASE_STORAGE_BUCKET"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="REPLACE_WITH_FIREBASE_MESSAGING_SENDER_ID"
NEXT_PUBLIC_FIREBASE_APP_ID="REPLACE_WITH_FIREBASE_APP_ID"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="REPLACE_WITH_FIREBASE_MEASUREMENT_ID"

# Firebase Admin configuration
FIREBASE_ADMIN_PROJECT_ID="REPLACE_WITH_FIREBASE_PROJECT_ID"
FIREBASE_ADMIN_CLIENT_EMAIL="REPLACE_WITH_FIREBASE_CLIENT_EMAIL"
FIREBASE_ADMIN_PRIVATE_KEY="REPLACE_WITH_FIREBASE_PRIVATE_KEY"
