generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserTier {
  FREE
  PRO
  TEAM
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String?
  password         String?
  tier             UserTier      @default(FREE)
  trialStart       DateTime?     @map("trial_start")
  trialEnd         DateTime?     @map("trial_end")
  stripeCustomerId String?       @unique
  createdAt        DateTime      @default(now())
  calculations     Calculation[]
  sharedCalculations SharedCalculation[]
  favorites        Favorite[]
  accounts         Account[]
  sessions         Session[]
  aiExplainFeedbacks AiExplainFeedback[] @relation("AiExplainFeedbacks")
}

model Calculation {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  toolSlug   String
  inputs     Json
  outputs    Json
  createdAt  DateTime @default(now())
  isFavorite Boolean  @default(false)
}

model SharedCalculation {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  toolSlug  String
  inputs    Json
  outputs   Json?
  isPublic  Boolean  @default(false)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([code])
  @@index([expiresAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  toolSlug  String
  createdAt DateTime @default(now())

  @@unique([userId, toolSlug])
}

// NextAuth.js / Auth.js models
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AiExplainFeedback {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation("AiExplainFeedbacks", fields: [userId], references: [id], onDelete: SetNull)
  toolId       String
  feedbackType String   // "up" or "down"
  question     String?
  response     String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([toolId])
  @@index([createdAt])
}

