{
  "name": "aiengineerslab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "tsx scripts/buildSearchIndex.ts",
    "postinstall": "prisma generate",
    "prebuild": "prisma generate && node scripts/check-assets.mjs && node scripts/check-i18n.mjs && node scripts/check-content-locales.mjs && node scripts/check-text-encoding.mjs && tsx scripts/buildSearchIndex.ts && node scripts/check-tool-docs.mjs && node scripts/check-featured-docs.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:a11y": "eslint --ext .tsx,.jsx src/ --rule \"jsx-a11y/control-has-associated-label:error\" --rule \"jsx-a11y/label-has-associated-control:error\" --rule \"jsx-a11y/no-static-element-interactions:error\" --rule \"jsx-a11y/click-events-have-key-events:error\" --rule \"jsx-a11y/interactive-supports-focus:error\" --rule \"jsx-a11y/no-noninteractive-element-interactions:error\" --rule \"jsx-a11y/no-noninteractive-tabindex:error\"",
    "i18n:report": "node scripts/report-i18n-status.mjs",
    "check:encoding": "node scripts/check-text-encoding.mjs",
    "lhci": "lhci autorun --config=.lighthouserc.js",
    "perf:ci": "npm run build && npm run lhci",
    "analyze": "cross-env ANALYZE=true npm run build",
    "bundle:stats": "node scripts/bundle-stats.mjs",
    "bundle:diff": "node scripts/bundle-stats.mjs",
    "test": "vitest run",
    "test:pdf": "tsx test-pdf-system.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.0",
    "@prisma/client": "^5.17.0",
    "@tanstack/react-virtual": "^3.13.19",
    "@vercel/speed-insights": "^1.3.1",
    "autoprefixer": "^10.4.22",
    "bcrypt": "^6.0.0",
    "chart.js": "^4.5.1",
    "firebase": "^12.7.0",
    "firebase-admin": "^12.7.0",
    "framer-motion": "^12.23.25",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.560.0",
    "lz-string": "^1.5.0",
    "nanoid": "^5.0.7",
    "next": "^16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-mdx-remote": "^6.0.0",
    "openai": "^6.9.1",
    "postcss": "^8.5.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "katex": "^0.16.8",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "prisma": "^5.17.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "cross-env": "^7.0.3"
  }
}
